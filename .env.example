# Copy to .env on each machine and fill in real secrets.

# ---- InfluxDB ----
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=change-me
INFLUXDB_ORG=casa
INFLUXDB_BUCKET_HISTORY=history
INFLUXDB_BUCKET_LIVE=live
INFLUXDB_RETENTION_HISTORY=31d
INFLUXDB_RETENTION_LIVE=48h
INFLUXDB_TOKEN=change-me-long-random-token

# ---- Collector (Modbus -> InfluxDB) ----
INVERTER_DEVICE=/dev/growatt
MODBUS_BAUD=9600
MODBUS_SLAVE=1
POLL_INTERVAL_LIVE=1
HISTORY_INTERVAL=60

# REG_COUNT >= 91: register 90 = battery current.
REG_COUNT=91
DEBUG_RAW=0

# ---- Alerts (ntfy) ----
NTFY_TOPIC=Alerta_6Kw
NTFY_URL=http://ntfy/Alerta_6Kw
ALERT_THRESHOLD_W=5500
ALERT_CLEAR_W=5000
ALERT_COOLDOWN_S=300
ALERT_DEBOUNCE_S=3

# ---- Battery / output / temperature alert thresholds ----
BAT_LOW_V=48.0
BAT_LOW_V_CLR=49.0
BAT_LOW_SOC=20
BAT_LOW_SOC_CLR=25
BAT_HIGH_V=57.0
BAT_HIGH_V_CLR=56.0
TEMP_HIGH=65
TEMP_HIGH_CLR=60
OUT_LOST_V=180
OUT_LOST_V_CLR=200
GRID_PRESENT_V=100
BATTERY_FIRST_MIN_V=48.0

# ---- Watchdog ----
WATCHDOG_FAILS=30

# ---- Grafana ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
