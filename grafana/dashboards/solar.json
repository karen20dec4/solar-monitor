      "options": {
        "mode": "html",
        "content": "<div id=\"battery-combo-widget\" class=\"battery-combo-widget\">\n  <style>\n    #battery-combo-widget { width: 100%; height: 100%; min-height: 220px; display: flex; align-items: center; justify-content: center; overflow: hidden; font-family: Inter, Roboto, Helvetica, Arial, sans-serif; --ok: #73BF69; --warn: #FF9830; --bad: #F2495C; --muted: #20242c; }\n    #battery-combo-widget .wrap { position: relative; width: min(100%, 520px); height: 100%; min-height: 220px; }\n    #battery-combo-widget svg { position: absolute; inset: 0; width: 100%; height: 100%; }\n    #battery-combo-widget .bat-w { position: absolute; left: 0; right: 0; top: 47%; transform: translateY(-50%); text-align: center; font-size: clamp(42px, 5.4vw, 72px); line-height: 1; font-weight: 500; color: var(--ok); }\n    #battery-combo-widget .bat-v { position: absolute; left: 0; right: 0; top: 72%; transform: translateY(-50%); text-align: center; font-size: clamp(34px, 4vw, 52px); line-height: 1; font-weight: 400; color: #5794F2; }\n  </style>\n  <div class=\"wrap\">\n    <svg viewBox=\"0 0 520 330\" aria-hidden=\"true\"><g id=\"battery-arc-bg\"></g><g id=\"battery-arc-fill\"></g><path id=\"battery-needle\" d=\"\" stroke=\"#11161d\" stroke-width=\"5\" stroke-linecap=\"round\" fill=\"none\"></path></svg>\n    <div class=\"bat-w\" id=\"battery-w\">-- W</div><div class=\"bat-v\" id=\"battery-v\">--.-- V</div>\n  </div>\n</div>\n<script>\n(function() {\n  var root = document.getElementById('battery-combo-widget');\n  if (!root) return;\n  var arcBg = root.querySelector('#battery-arc-bg');\n  var arcFill = root.querySelector('#battery-arc-fill');\n  var needle = root.querySelector('#battery-needle');\n  var wEl = root.querySelector('#battery-w');\n  var vEl = root.querySelector('#battery-v');\n  var min = 46, max = 58, cx = 260, cy = 200, r = 190;\n  var start = 205, end = -25;\n  var colors = { green: '#73BF69', orange: '#FF9830', red: '#F2495C', dark: '#20242c' };\n  var bands = [\n    { from: 46, to: 48, color: colors.red },\n    { from: 48, to: 50, color: colors.orange },\n    { from: 50, to: 56.5, color: colors.green },\n    { from: 56.5, to: 57, color: colors.orange },\n    { from: 57, to: 58, color: colors.red }\n  ];\n  function polar(deg) { var a = deg * Math.PI / 180; return { x: cx + r * Math.cos(a), y: cy - r * Math.sin(a) }; }\n  function arcPath(a0, a1) { var p0 = polar(a0), p1 = polar(a1); var large = Math.abs(a1 - a0) > 180 ? 1 : 0; return 'M ' + p0.x.toFixed(2) + ' ' + p0.y.toFixed(2) + ' A ' + r + ' ' + r + ' 0 ' + large + ' 1 ' + p1.x.toFixed(2) + ' ' + p1.y.toFixed(2); }\n  function angleFor(value) { return start + ((value - min) / (max - min)) * (end - start); }\n  function addArc(target, from, to, color, width) { if (to <= from) return; var p = document.createElementNS('http://www.w3.org/2000/svg', 'path'); p.setAttribute('d', arcPath(angleFor(from), angleFor(to))); p.setAttribute('stroke', color); p.setAttribute('stroke-width', width || '42'); p.setAttribute('stroke-linecap', 'butt'); p.setAttribute('fill', 'none'); target.appendChild(p); }\n  function drawBase() { if (root.dataset.baseDrawn) return; for (var i = 0; i < bands.length; i++) addArc(arcBg, bands[i].from, bands[i].to, colors.dark, '42'); root.dataset.baseDrawn = '1'; }\n  function renderFill(volts) { var fillTo = Math.max(min, Math.min(max, volts)); arcFill.innerHTML = ''; for (var i = 0; i < bands.length; i++) { var b = bands[i]; addArc(arcFill, b.from, Math.min(b.to, fillTo), b.color, '42'); } }\n  drawBase();\n  var query = 'from(bucket: \"live\") |> range(start:-10s) |> filter(fn:(r)=> r._measurement==\"inverter\" and (r._field==\"battery_voltage\" or r._field==\"battery_power\" or r._field==\"battery_display_power\")) |> last()';\n  async function read() {\n    try {\n      var res = await fetch('/api/ds/query', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ queries: [{ refId: 'A', datasource: { type: 'influxdb', uid: 'influxdb' }, query: query, intervalMs: 1000, maxDataPoints: 10 }], from: 'now-10s', to: 'now' }) });\n      var json = await res.json();\n      var frames = (json.results && json.results.A && json.results.A.frames) || [];\n      var volts = NaN, watts = NaN, displayWatts = NaN;\n      for (var i = 0; i < frames.length; i++) { var frame = frames[i]; var fields = (frame.schema && frame.schema.fields) || []; var numberField = fields.find(function(f) { return f.type === 'number'; }); var values = (frame.data && frame.data.values && frame.data.values[1]) || []; var value = values[values.length - 1]; if (numberField && numberField.name === 'battery_voltage') volts = Number(value); if (numberField && numberField.name === 'battery_power') watts = Number(value); if (numberField && numberField.name === 'battery_display_power') displayWatts = Number(value); }\n      if (Number.isFinite(displayWatts)) watts = displayWatts;\n      if (Number.isFinite(volts)) { vEl.textContent = volts.toFixed(2) + ' V'; vEl.style.color = '#5794F2'; renderFill(volts); var a = angleFor(Math.max(min, Math.min(max, volts))); needle.setAttribute('d', arcPath(a - 0.5, a + 0.5)); }\n      if (Number.isFinite(watts)) { wEl.textContent = Math.round(watts) + ' W'; wEl.style.color = watts >= 0 ? colors.green : colors.red; }\n    } catch (e) { wEl.textContent = 'date?'; }\n  }\n  if (window.__batteryComboTimer) clearInterval(window.__batteryComboTimer);\n  read();\n  window.__batteryComboTimer = setInterval(read, 1000);\n})();\n</script>"
