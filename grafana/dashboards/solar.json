        "mode": "html",
        "content": "<div id=\"house-combo-widget\" class=\"house-combo-widget\">\n  <style>\n    #house-combo-widget { width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; overflow: hidden; font-family: Inter, Roboto, Helvetica, Arial, sans-serif; --pv: #73BF69; --bat: #FADE2A; --grid: #F2495C; }\n    #house-combo-widget .house-source { width: 100%; display: flex; align-items: center; justify-content: center; gap: 10px; flex-wrap: wrap; text-align: center; font-size: clamp(22px, 2.4vw, 38px); line-height: 1; font-weight: 500; margin-bottom: 4px; white-space: normal; }\n    #house-combo-widget .house-source span { display: inline-block; }\n    #house-combo-widget .house-value { width: 100%; text-align: center; font-size: clamp(44px, 5.6vw, 82px); line-height: 0.95; font-weight: 500; color: var(--pv); white-space: nowrap; }\n    #house-combo-widget .pv { color: var(--pv); }\n    #house-combo-widget .bat { color: var(--bat); }\n    #house-combo-widget .grid { color: var(--grid); }\n  </style>\n  <div class=\"house-source\" id=\"house-source\">--</div>\n  <div class=\"house-value\" id=\"house-value\">-- W</div>\n</div>\n<script>\n(function() {\n  var root = document.getElementById('house-combo-widget');\n  if (!root) return;\n  var sourceEl = root.querySelector('#house-source');\n  var valueEl = root.querySelector('#house-value');\n  var colors = { pv: '#73BF69', bat: '#FADE2A', grid: '#F2495C' };\n  var query = 'from(bucket: \"live\") |> range(start:-10s) |> filter(fn:(r)=> r._measurement==\"inverter\" and (r._field==\"output_power\" or r._field==\"pv_power\" or r._field==\"battery_power\" or r._field==\"battery_support_power\" or r._field==\"grid_import_power\")) |> last()';\n  async function read() {\n    try {\n      var res = await fetch('/api/ds/query', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ queries: [{ refId: 'A', datasource: { type: 'influxdb', uid: 'influxdb' }, query: query, intervalMs: 1000, maxDataPoints: 10 }], from: 'now-10s', to: 'now' }) });\n      var json = await res.json();\n      var frames = (json.results && json.results.A && json.results.A.frames) || [];\n      var data = {};\n      for (var i = 0; i < frames.length; i++) { var frame = frames[i]; var fields = (frame.schema && frame.schema.fields) || []; var numberField = fields.find(function(f) { return f.type === 'number'; }); var values = (frame.data && frame.data.values && frame.data.values[1]) || []; var value = values[values.length - 1]; if (numberField) data[numberField.name] = Number(value); }\n      var out = Number.isFinite(data.output_power) ? data.output_power : NaN;\n      var pv = Number.isFinite(data.pv_power) ? data.pv_power : 0;\n      var bat = Number.isFinite(data.battery_support_power) ? data.battery_support_power : (Number.isFinite(data.battery_power) ? Math.max(-data.battery_power, 0) : 0);\n      var grid = Number.isFinite(data.grid_import_power) ? data.grid_import_power : 0;\n      var dead = 50;\n      var active = [];\n      if (pv > dead) active.push({ cls: 'pv', label: '☀️ PV' });\n      if (bat > dead) active.push({ cls: 'bat', label: '🔋 Baterie' });\n      if (grid > dead) active.push({ cls: 'grid', label: '⚡ Retea' });\n      if (!active.length && out > dead) active.push({ cls: 'grid', label: '⚡ Retea' });\n      if (!active.length) active.push({ cls: 'pv', label: '☀️ PV' });\n      sourceEl.innerHTML = active.map(function(item, index) {\n        var prefix = index === 0 ? '' : '+';\n        return '<span class=\"' + item.cls + '\">' + prefix + ' ' + item.label + '</span>';\n      }).join('');\n      var hasGrid = active.some(function(item) { return item.cls === 'grid'; });\n      var hasBattery = active.some(function(item) { return item.cls === 'bat'; });\n      var color = hasGrid ? colors.grid : hasBattery ? colors.bat : colors.pv;\n      if (Number.isFinite(out)) valueEl.textContent = Math.round(out) + ' W';\n      valueEl.style.color = color;\n    } catch (e) { sourceEl.textContent = 'date?'; valueEl.textContent = '-- W'; }\n  }\n  if (window.__houseComboTimer) clearInterval(window.__houseComboTimer);\n  read();\n  window.__houseComboTimer = setInterval(read, 1000);\n})();\n</script>"
