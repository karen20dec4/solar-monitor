      "options": {
        "mode": "html",
        "content": "<div id=\"flow-widget\" class=\"flow-widget\">\n  <style>\n    #flow-widget { width:100%; height:100%; min-height:240px; display:flex; align-items:center; justify-content:center; overflow:hidden; font-family: Inter, Roboto, Helvetica, Arial, sans-serif; }\n    #flow-widget svg { width:100%; height:100%; }\n    #flow-widget .label { font-size:19px; fill:#aeb8c4; }\n    #flow-widget .val { font-size:30px; font-weight:600; }\n    #flow-widget .flow { stroke-width:6; fill:none; stroke-linecap:round; opacity:0.16; }\n    #flow-widget .flow.active { opacity:1; stroke-dasharray:14 10; animation: fdash 1s linear infinite; }\n    #flow-widget .flow.active.rev { animation: fdashrev 1s linear infinite; }\n    @keyframes fdash { to { stroke-dashoffset:-24; } }\n    @keyframes fdashrev { to { stroke-dashoffset:24; } }\n  </style>\n  <svg viewBox=\"0 0 600 290\" preserveAspectRatio=\"xMidYMid meet\" aria-hidden=\"true\">\n    <path id=\"f-pv\"   class=\"flow\" d=\"M300 86 L300 183\" stroke=\"#73BF69\"></path>\n    <path id=\"f-bat\"  class=\"flow\" d=\"M168 225 L250 225\" stroke=\"#FADE2A\"></path>\n    <path id=\"f-grid\" class=\"flow\" d=\"M432 225 L350 225\" stroke=\"#F2495C\"></path>\n    <g><rect x=\"230\" y=\"14\" width=\"140\" height=\"70\" rx=\"10\" fill=\"#16210f\" stroke=\"#73BF69\" stroke-width=\"2\"></rect>\n      <text x=\"300\" y=\"41\" text-anchor=\"middle\" class=\"label\">&#9728;&#65039; PV</text>\n      <text x=\"300\" y=\"72\" text-anchor=\"middle\" class=\"val\" id=\"v-pv\" fill=\"#73BF69\">-- W</text></g>\n    <g><rect x=\"230\" y=\"186\" width=\"140\" height=\"78\" rx=\"10\" fill=\"#141b25\" stroke=\"#5794F2\" stroke-width=\"2\"></rect>\n      <text x=\"300\" y=\"215\" text-anchor=\"middle\" class=\"label\">&#127968; Cas&#259;</text>\n      <text x=\"300\" y=\"247\" text-anchor=\"middle\" class=\"val\" id=\"v-house\" fill=\"#e6edf5\">-- W</text></g>\n    <g><rect x=\"30\" y=\"186\" width=\"138\" height=\"78\" rx=\"10\" fill=\"#21210d\" stroke=\"#FADE2A\" stroke-width=\"2\"></rect>\n      <text x=\"99\" y=\"215\" text-anchor=\"middle\" class=\"label\" id=\"l-bat\">&#128267; Baterie</text>\n      <text x=\"99\" y=\"247\" text-anchor=\"middle\" class=\"val\" id=\"v-bat\" fill=\"#FADE2A\">-- W</text></g>\n    <g><rect x=\"432\" y=\"186\" width=\"138\" height=\"78\" rx=\"10\" fill=\"#23110f\" stroke=\"#F2495C\" stroke-width=\"2\"></rect>\n      <text x=\"501\" y=\"215\" text-anchor=\"middle\" class=\"label\">&#9889; Re&#539;ea</text>\n      <text x=\"501\" y=\"247\" text-anchor=\"middle\" class=\"val\" id=\"v-grid\" fill=\"#F2495C\">-- W</text></g>\n  </svg>\n</div>\n<script>\n(function() {\n  var root = document.getElementById('flow-widget');\n  if (!root) return;\n  var query = 'from(bucket: \"live\") |> range(start:-10s) |> filter(fn:(r)=> r._measurement==\"inverter\" and (r._field==\"pv_power\" or r._field==\"output_power\" or r._field==\"battery_display_power\" or r._field==\"battery_charge_power\" or r._field==\"battery_support_power\" or r._field==\"grid_import_power\" or r._field==\"grid_charge_power\")) |> last()';\n  function setNode(id, w) { var el = root.querySelector(id); if (el) el.textContent = Math.round(w) + ' W'; }\n  function setFlow(id, active, rev) { var el = root.querySelector(id); if (!el) return; el.setAttribute('class', 'flow' + (active ? ' active' : '') + (active && rev ? ' rev' : '')); }\n  async function read() {\n    try {\n      var res = await fetch('/api/ds/query', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ queries: [{ refId: 'A', datasource: { type: 'influxdb', uid: 'influxdb' }, query: query, intervalMs: 1000, maxDataPoints: 10 }], from: 'now-10s', to: 'now' }) });\n      var json = await res.json();\n      var frames = (json.results && json.results.A && json.results.A.frames) || [];\n      var d = {};\n      for (var i = 0; i < frames.length; i++) { var fr = frames[i]; var fs = (fr.schema && fr.schema.fields) || []; var nf = fs.find(function(f) { return f.type === 'number'; }); var vs = (fr.data && fr.data.values && fr.data.values[1]) || []; var v = vs[vs.length - 1]; if (nf) d[nf.name] = Number(v); }\n      var dead = 50;\n      var pv = d.pv_power || 0, house = d.output_power || 0;\n      var batDisp = d.battery_display_power || 0, batChg = d.battery_charge_power || 0, batSup = d.battery_support_power || 0;\n      var gridImp = d.grid_import_power || 0, gridChg = d.grid_charge_power || 0;\n      setNode('#v-pv', pv);\n      setNode('#v-house', house);\n      setNode('#v-bat', Math.abs(batDisp));\n      setNode('#v-grid', gridImp + gridChg);\n      var charging = (batChg > dead) || (batDisp > dead);\n      var discharging = (batSup > dead) || (batDisp < -dead);\n      var labBat = root.querySelector('#l-bat');\n      if (labBat) labBat.textContent = charging ? '🔋 Incarca' : (discharging ? '🔋 Descarca' : '🔋 Baterie');\n      setFlow('#f-pv', pv > dead, false);\n      setFlow('#f-bat', charging || discharging, charging);\n      setFlow('#f-grid', (gridImp + gridChg) > dead, false);\n    } catch (e) {}\n  }\n  if (window.__flowTimer) clearInterval(window.__flowTimer);\n  read();\n  window.__flowTimer = setInterval(read, 1000);\n})();\n</script>"
